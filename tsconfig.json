{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ESNext",
    "moduleResolution": "Node",
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "baseUrl": "."
  },
  "include": ["assets/**/*.ts"],
  "exclude": ["library", "local", "temp", "build", "node_modules"]
}
